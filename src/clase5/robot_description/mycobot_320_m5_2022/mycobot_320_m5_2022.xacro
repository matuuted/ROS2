<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="myCobot320">

  <xacro:property name="width" value=".2" />

  <xacro:property name="joint_effort" value="56.0" />
  <xacro:property name="joint_velocity" value="2.792527" />
  <xacro:property name="joint_damping" value="0.0" />
  <xacro:property name="joint_friction" value="0.0" />
  <xacro:property name="base_mass" value="0.12" />
  <xacro:property name="link1_mass" value="0.12" />
  <xacro:property name="link2_mass" value="0.19" />
  <xacro:property name="link3_mass" value="0.16" />
  <xacro:property name="link4_mass" value="0.124" />
  <xacro:property name="link5_mass" value="0.11" />
  <xacro:property name="link6_mass" value="0.0739" />
  <xacro:property name="flange_mass" value="0.035" />

  <xacro:macro name="link_inertial" params="mass ixx iyy izz">
    <inertial>
      <origin xyz="0 0 0.0" rpy="0 0 0" />
      <mass value="${mass}" />
      <inertia ixx="${ixx}" ixy="0.0" ixz="0.0" iyy="${iyy}" iyz="0.0" izz="${izz}" />
    </inertial>
  </xacro:macro>

  <link name="base_link">
    <xacro:link_inertial mass="${base_mass}" ixx="0.000148" iyy="0.000148" izz="0.000096"/>

    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/base.dae" />
      </geometry>
      <origin xyz="0.0 0 0 " rpy=" 0 0 1.5708" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/base.dae" />
      </geometry>
      <origin xyz="0.0 0 0 " rpy=" 0 0 1.5708" />
    </collision>
  </link>

  <link name="link1">    
    <xacro:link_inertial mass="${link1_mass}" ixx="0.000148" iyy="0.000148" izz="0.000096"/>

    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link1.dae" />
      </geometry>

      <origin xyz="0.0 0.0 -0.078 " rpy=" 0 0 1.5708" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link1.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.078 " rpy=" 0 0 1.5708" />
    </collision>
  </link>


  <link name="link2">    
    <xacro:link_inertial mass="${link2_mass}" ixx="0.000148" iyy="0.000148" izz="0.000096"/>

    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link2.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.04 " rpy=" 0 1.5708 0" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link2.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.04 " rpy=" 0 1.5708 0" />
    </collision>
  </link>


  <link name="link3">    
    <xacro:link_inertial mass="${link3_mass}" ixx="0.000148" iyy="0.000148" izz="0.000096"/>    
    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link3.dae" />
      </geometry>
      <origin xyz="0.0 0.0 0.039 " rpy=" 1.5708 1.5708 1.5708" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link3.dae" />
      </geometry>
      <origin xyz="0.0 0.0 0.039 " rpy=" 1.5708 1.5708 1.5708" />
    </collision>
  </link>


  <link name="link4">    
    <xacro:link_inertial mass="${link4_mass}" ixx="0.000103" iyy="0.000103" izz="0.000096"/>
    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link4.dae" />
      </geometry>
      <origin xyz="0.0 -0.0024 -0.05" rpy=" 1.5708 1.5708 0" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link4.dae" />
      </geometry>
      <origin xyz="0.0 -0.0024 -0.05" rpy=" 1.5708 1.5708 0" />
    </collision>
  </link>


  <link name="link5">
    <xacro:link_inertial mass="${link5_mass}" ixx="0.000103" iyy="0.000103" izz="0.000096"/>
    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link5.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.05 " rpy=" 0  0 -1.5708" />
    </visual>
    <collision>
      <origin xyz="0 0 -0.01" rpy="0 0 -1.5708" />
      <geometry>
        <box size="0.103 0.059 0.080" />
      </geometry>
    </collision>
  </link>


  <link name="link6">   
    <xacro:link_inertial mass="${link6_mass}" ixx="0.00006649" iyy="0.00006649" izz="0.000096"/> 
    <visual>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link6.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.0115 " rpy=" 1.5708 1.5708 0" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://clase5/robot_description/mycobot_320_m5_2022/link6.dae" />
      </geometry>
      <origin xyz="0.0 0.0 -0.0115 " rpy=" 1.5708 1.5708 0" />
    </collision>
  </link>


  <joint name="joint2_to_joint1" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-2.93" upper="2.93" velocity="0" />
    <parent link="base_link" />
    <child link="link1" />
    <origin xyz="0 0 0.1739" rpy="0 0 0" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>


  <joint name="joint3_to_joint2" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-2.35" upper="2.35" velocity="0" />
    <parent link="link1" />
    <child link="link2" />
    <origin xyz="0 -0.08878 0" rpy="0 -1.5708 1.5708" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>


  <joint name="joint4_to_joint3" type="revolute">
    <axis xyz=" 0 0 1" />
    <limit effort="1000.0" lower="-2.53" upper="2.53" velocity="0" />
    <parent link="link2" />
    <child link="link3" />
    <origin xyz="0.135 0 -0.08878   " rpy="0 0 0" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <joint name="joint5_to_joint4" type="revolute">
    <axis xyz=" 0 0 1" />
    <limit effort="1000.0" lower="-2.53" upper="2.53" velocity="0" />
    <parent link="link3" />
    <child link="link4" />
    <origin xyz="0.120 0 0.08878 " rpy=" 0 0 1.57080" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <joint name="joint6_to_joint5" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-2.93" upper="2.93" velocity="0" />
    <parent link="link4" />
    <child link="link5" />
    <origin xyz="0 -0.095 0.0" rpy="1.5708 0 0" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <joint name="joint6output_to_joint6" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-3.14" upper="3.14" velocity="0" />
    <parent link="link5" />
    <child link="link6" />
    <origin xyz="0 0.0655 0.0" rpy="-1.5708 0 0" />
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>


</robot>